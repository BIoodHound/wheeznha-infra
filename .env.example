# Database admin (postgres superuser for weeznha_db)
DB_NAME=weeznha_db
DB_USERNAME=weeznha_user
DB_PASSWORD=change_me_strong_password

# Per-service database roles — each owns only its own schema.
# Created by init-db.sh on first postgres boot.
AUTH_DB_PASSWORD=change_me_auth
SHOPPINGLIST_DB_PASSWORD=change_me_shoppinglist
WALLET_DB_PASSWORD=change_me_wallet
PALETTE_DB_PASSWORD=change_me_palette

# JWT — RS256 keypair. Generate once into ./keys (gitignored):
#   mkdir -p keys
#   openssl genpkey -algorithm RSA -pkeyopt rsa_keygen_bits:2048 -out keys/jwt-private.pem
#   openssl rsa -in keys/jwt-private.pem -pubout -out keys/jwt-public.pem
# auth-service signs with the private key; app services verify with the public key.

# CORS — auth-service allowed origins (weeznha.com login page)
CORS_ALLOWED_ORIGINS=https://weeznha.com,http://localhost:5173,http://localhost:3000

# Per-service CORS origins
ALLOWED_ORIGINS_SHOPPINGLIST=http://localhost:3535,https://list.weeznha.com
ALLOWED_ORIGINS_WALLET=http://localhost:3000,https://wallet.weeznha.com
ALLOWED_ORIGINS_PALETTE=http://localhost:5173,https://palette.weeznha.com
